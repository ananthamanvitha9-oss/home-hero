# ==============================================================================
# HOMEHERO ROOT CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Backend Server Configurations
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# ------------------------------------------------------------------------------
# 2. Database connection configurations
# ------------------------------------------------------------------------------
# Set local or MongoDB Atlas connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/homehero?retryWrites=true&w=majority

# ------------------------------------------------------------------------------
# 3. Authentication Secrets
# ------------------------------------------------------------------------------
JWT_SECRET=your_32_character_cryptographically_secure_jwt_secret_key
JWT_EXPIRES_IN=24h

# ------------------------------------------------------------------------------
# 4. Third-Party Integrations
# ------------------------------------------------------------------------------
# Razorpay Credentials (Test keys during development)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Google Maps Platform Key (Geocoding & Matrix queries)
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Service Account JSON (Must be single-line JSON string for push alerts)
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "homehero-fcm", "private_key_id": "xxx"}

# ------------------------------------------------------------------------------
# 5. Frontend Client Configurations
# ------------------------------------------------------------------------------
# API Server base URL proxy path
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
